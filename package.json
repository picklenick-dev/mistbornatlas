{
	"name": "mistborn-interactive-map",
	"version": "0.8.0",
	"description": "Interactive chrono-cartographic visualization of the Mistborn Original Trilogy",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
		"format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json}\" \"*.json\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx,scss,css,json}\" \"*.json\""
	},
	"dependencies": {
		"@tsparticles/react": "^3.0.0",
		"@tsparticles/slim": "^3.9.1",
		"leaflet": "^1.9.4",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-leaflet": "^4.2.1"
	},
	"devDependencies": {
		"@tsparticles/engine": "^3.9.1",
		"@types/leaflet": "^1.9.8",
		"@types/react": "^18.2.43",
		"@types/react-dom": "^18.2.17",
		"@typescript-eslint/eslint-plugin": "^8.56.0",
		"@typescript-eslint/parser": "^8.56.0",
		"@vitejs/plugin-react": "^4.2.1",
		"eslint": "^8.55.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react-hooks": "^4.6.0",
		"eslint-plugin-react-refresh": "^0.4.5",
		"prettier": "^3.8.1",
		"sass": "^1.69.5",
		"typescript": "^5.3.3",
		"vite": "^5.0.8"
	}
}
